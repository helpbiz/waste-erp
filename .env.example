# ─────────────────────────────────────────────────────────
# CleanERP 프로덕션 환경변수 템플릿
# 사용: cp .env.example .env && 시크릿 채우기
# ─────────────────────────────────────────────────────────

# ════════════ 데이터베이스 ════════════
# Docker Compose 사용 시 hostname=postgres / 외부 사용 시 실 호스트
DATABASE_URL="postgresql://cleanerp:CHANGE_ME_STRONG_PASSWORD@postgres:5432/cleanerp_prod?schema=public&sslmode=prefer"

# Compose 환경에서만 사용 (Postgres 컨테이너 부팅용)
POSTGRES_USER=cleanerp
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_OR_MORE
POSTGRES_DB=cleanerp_prod
POSTGRES_PORT=5432

# 개발 (docker-compose.yml — wci-waste-erp-db)
# DATABASE_URL="postgresql://wciuser:wcipass@localhost:5433/wci_waste_erp?schema=public"

# ════════════ 인증 / 세션 ════════════
# 32바이트 이상 무작위 — openssl rand -base64 48
JWT_SECRET="CHANGE_ME_TO_RANDOM_48_BYTES_MINIMUM_FOR_PRODUCTION"

# NOC 무인 단말 long-lived JWT 발급 시크릿 (POST /api/auth/noc-issue)
# - 미설정 시 엔드포인트는 503 (기능 비활성)
# - 32바이트 이상 무작위 — openssl rand -base64 48
# - 노출 시 즉시 회전 + 컨테이너 재시작
NOC_ISSUE_SECRET="CHANGE_ME_OPTIONAL_FOR_NOC_LONG_LIVED_TOKEN_ISSUER"

# 앱 포트 (외부 노출)
APP_PORT=3000

# ════════════ KMS (필드 단위 암호화 키) ════════════
# 옵션: local | aws | vault
KMS_PROVIDER=local

# local — 32바이트 base64: openssl rand -base64 32
KMS_LOCAL_KEY=CHANGE_ME_BASE64_32_BYTE_KEY_FOR_AES256_GCM

# AWS KMS (운영 권장)
# KMS_PROVIDER=aws
# AWS_REGION=ap-northeast-2
# AWS_KMS_KEY_ID=arn:aws:kms:ap-northeast-2:<acct>:key/<id>
# AWS_KMS_ENCRYPTED_DEK_BASE64=...   # generate-data-key 결과
# # npm install @aws-sdk/client-kms

# HashiCorp Vault Transit
# KMS_PROVIDER=vault
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=hvs.xxxxxx
# VAULT_KEY_NAME=cleanerp-data
# VAULT_ENCRYPTED_DEK=vault:v1:...

# ════════════ SMS / 알림톡 ════════════
# simulation | solapi | webhook
SMS_PROVIDER=simulation
# SOLAPI (운영 권장 — https://solapi.com)
# SMS_PROVIDER=solapi
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# SMS_FROM=01012345678
# Slack/MS Teams 통합용
# SMS_PROVIDER=webhook
# SMS_WEBHOOK_URL=https://hooks.slack.com/services/...

# ════════════ 기상 ════════════
# open-meteo (무료, default) | kma | openweather
WEATHER_PROVIDER=open-meteo
# 기상청 APIHub (가장 정확)
# WEATHER_PROVIDER=kma
# KMA_API_KEY=
# KMA_GRID_NX=61      # 강남구 기본
# KMA_GRID_NY=126
# OpenWeather (글로벌)
# OPENWEATHER_API_KEY=
WEATHER_LAT=37.4979
WEATHER_LNG=127.0276
WEATHER_REGION="서울특별시 강남구"

# ════════════ Cron ════════════
# 외부 cron(Vercel/K8s/GitHub Actions)에서 호출 시 Bearer
# openssl rand -hex 32
CRON_SECRET=CHANGE_ME_RANDOM_HEX_FOR_CRON_AUTH

# ════════════ ORS (실시간 차량조회 - 추천경로) ════════════
# 미설정 시 Haversine 직선 거리 fallback (gis-cost 알고리즘 동등)
# 옵션 1: 자체호스팅 — docker compose -f docker-compose.prod.yml --profile with-ors up
ORS_URL=http://ors:8080/ors
# 옵션 2: 클라우드 ORS (https://openrouteservice.org)
# ORS_API_KEY=
ORS_PROFILE=driving-car
ORS_TIMEOUT_MS=5000

# ════════════ 빼기/공유 App (대형폐기물) ════════════
# 미설정 시 lib/ppaegi.ts mock provider 사용
# PPAEGI_API_BASE=https://bbegi.com/api
# PPAEGI_LOGIN_URL=https://bbegi.com/login

# ════════════ Seed (개발만) ════════════
# 운영에서는 prisma/seed.ts 실행 X — 시드 비밀번호로 운영 계정 만들지 마세요
SEED_PASSWORD=changeme1234!

# ─────────────────────────────────────────────────────────
# 운영 보안 체크리스트
# ─────────────────────────────────────────────────────────
# [ ] JWT_SECRET 48바이트 이상 무작위 (openssl rand -base64 48)
# [ ] KMS_LOCAL_KEY 32바이트 무작위 base64 (또는 KMS_PROVIDER=aws/vault)
# [ ] POSTGRES_PASSWORD 32자 이상
# [ ] CRON_SECRET 무작위 hex (외부 cron만 Bearer 호출 가능)
# [ ] HTTPS 종료 (Nginx/Traefik 리버스 프록시 + Let's Encrypt)
# [ ] DATABASE_URL ?sslmode=require 강제
# [ ] 개발용 test/test 계정 prisma/seed.ts에서 제거 (또는 SEED_PASSWORD 변경)
# [ ] 시드 5 Role 계정 (super/muni/company/manager/worker) 비밀번호 즉시 변경
# [ ] PWA 아이콘을 실제 디자인으로 교체 (public/icons/icon-192.png 등)
# [ ] PostgreSQL 자동 백업 (pg_dump cron + S3 업로드)
# [ ] 로그/감사 (audit_logs 테이블 보존 + Sentry/Datadog)
# [ ] Cron 외부 등록 (매일 03:00 bulky-waste-import / 17:00 bulky-waste-resolve)
# [ ] PostGIS 확장 (자체 ORS 호스팅 시 필요 — docker exec 후 CREATE EXTENSION postgis)

{
  "name": "waste-erp",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "지자체 생활폐기물 수집운반 ERP — Phase 1A (인증/RBAC/근태)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "e2e": "playwright test",
    "e2e:mobile": "playwright test --project=375-iPhone-SE --project=393-Pixel7 --project=360-GalaxyS --project=768-iPad mobile-responsive.spec.ts",
    "e2e:visual": "playwright test --project=375-iPhone-SE --project=393-Pixel7 --project=360-GalaxyS --project=768-iPad visual-regression.spec.ts",
    "e2e:tab-modal": "playwright test --project=375-iPhone-SE --project=393-Pixel7 --project=360-GalaxyS --project=768-iPad tab-modal.spec.ts",
    "e2e:login-flow": "playwright test --project=375-iPhone-SE login-flow.spec.ts",
    "e2e:a11y": "playwright test --project=375-iPhone-SE a11y.spec.ts",
    "e2e:update": "playwright test --update-snapshots --project=375-iPhone-SE --project=393-Pixel7 --project=360-GalaxyS --project=768-iPad visual-regression.spec.ts",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "jose": "^5.6.3",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.39",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
